  "description": "A live NHL standings tracker with playoff status indicators, fan ownership tracking, and upcoming game information. This project provides a clean, responsive interface for tracking teams as they advance toward the NHL Finals.",
  "main": "index.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "test": "npx playwright test",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:desktop": "npx playwright test --project=desktop-chrome",
    "test:e2e:mobile": "npx playwright test --project=mobile-iphone",
    "test:e2e:report": "npx playwright show-report e2e/report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@primer/css": "^22.0.2",
    "chart.js": "^4.5.1"
  },
