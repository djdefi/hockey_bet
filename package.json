{
  "name": "hockey_bet",
  "version": "1.0.0",
  "description": "A live NHL standings tracker with playoff status indicators, fan ownership tracking, and upcoming game information. This project provides a clean, responsive interface for tracking teams as they advance toward the NHL Finals.",
  "main": "index.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "build": "bundle exec ruby update_standings.rb",
    "serve:site": "npx serve _site -l 8765 --no-clipboard",
    "test": "npm run test:e2e",
    "test:ruby": "bundle exec rspec",
    "test:e2e": "npx playwright test",
    "test:all": "npm run test:ruby && npm run test:e2e",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:desktop": "npx playwright test --project=desktop-chrome",
    "test:e2e:mobile": "npx playwright test --project=mobile-iphone",
    "test:e2e:report": "npx playwright show-report e2e/report",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@primer/css": "^22.1.1",
    "chart.js": "^4.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "serve": "^14.2.6"
  }
}
